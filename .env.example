# Core app
APP_ENV=production

# Single exposed port (nginx reverse proxy serves everything)
APP_PORT=80

# Paths (Unraid host path)
MEDIA_ROOT_HOST=/mnt/user/indygestion

# Upload config
TUSD_MAX_SIZE=500GB
TUSD_WEBHOOK_SECRET=change-this-to-a-long-random-secret

# PostgreSQL
POSTGRES_USER=indygestion
POSTGRES_PASSWORD=indygestion_strong_password
POSTGRES_DB=indygestion
DATABASE_URL=postgresql+asyncpg://indygestion:indygestion_strong_password@postgres:5432/indygestion

# Redis/Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Whisper / ML
WHISPER_MODEL=small

# Device watcher
AUTO_INGEST=false
MIN_FILE_SIZE_MB=10
VIDEO_EXTENSIONS=.mov,.mp4,.mxf,.avi,.braw,.mkv,.mts
