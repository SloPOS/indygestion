# Core app
APP_ENV=production
FRONTEND_PORT=3000
BACKEND_PORT=8000
TUSD_PORT=1080
POSTGRES_PORT=5432
REDIS_PORT=6379

# Paths (Unraid host path)
MEDIA_ROOT_HOST=/media/indygestion

# API and upload endpoints
API_BASE_URL=http://localhost:8000
TUSD_ENDPOINT=http://localhost:1080/files
TUSD_MAX_SIZE=500GB
TUSD_WEBHOOK_SECRET=change-this-to-a-long-random-secret

# PostgreSQL
POSTGRES_USER=indygestion
POSTGRES_PASSWORD=indygestion_strong_password
POSTGRES_DB=indygestion
DATABASE_URL=postgresql+asyncpg://indygestion:indygestion_strong_password@postgres:5432/indygestion

# Redis/Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Whisper / ML
WHISPER_MODEL=small

# Device watcher
AUTO_INGEST=false
MIN_FILE_SIZE_MB=10
VIDEO_EXTENSIONS=.mov,.mp4,.mxf,.avi,.braw,.mkv,.mts
